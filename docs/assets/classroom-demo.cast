{"version": 2, "width": 100, "height": 30, "timestamp": 1748390400, "env": {"TERM": "xterm-256color", "SHELL": "/bin/zsh"}, "title": "classroom-submit end-to-end demo"}
[0.0, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[0.8, "o", "classroom-submit --help\r\n"]
[1.1, "o", "\u001b[38;5;183mclassroom-submit\u001b[0m — atomic Google Classroom submission via REST API.\r\n\r\n\u001b[38;5;152mUSAGE\u001b[0m\r\n  classroom-submit <command> [flags]\r\n\r\n\u001b[38;5;152mCOMMANDS\u001b[0m\r\n  auth          One-time OAuth installed-app flow (loopback :8765)\r\n  find          List active-course assignments by title/description query\r\n  submit-file   Upload + attach + turn-in atomically\r\n  submit        Skip search: explicit course + coursework + drive-file IDs\r\n  status        Check current submission state\r\n\r\n\u001b[38;5;152mFLAGS\u001b[0m\r\n  --file <path>          Local file to submit\r\n  --query <text>         Match assignments by title/description substring\r\n  --course <id>          Explicit course ID (skip search)\r\n  --coursework <id>      Explicit coursework ID (skip search)\r\n  --attach-only          Stop after modifyAttachments (draft mode)\r\n  --output <json|text>   Output format (default: text)\r\n  -h, --help             Show command-specific help\r\n\r\n"]
[3.4, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[3.7, "o", "classroom-submit find \"Lista 3\" --terse\r\n"]
[4.1, "o", "ODUxMzc0NzU3ODU3  Nzk3MDIxMjk3MjU4  2026-05-30  Compiladores  Lista 3 — análise sintática LL(1)\r\n"]
[5.4, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[5.8, "o", "classroom-submit submit-file --file ./lista3.pdf --query \"Lista 3\"\r\n"]
[6.2, "o", "\u001b[38;5;152m→\u001b[0m rclone copy ./lista3.pdf gdrive-uni:Classroom-Submissions-2026.1/\r\n"]
[7.4, "o", "\u001b[38;5;152m→\u001b[0m resolved drive_file_id=1Pg_YdVT-NRmiKoAacz1Sf21XJ-MX4vRJ\r\n"]
[8.1, "o", "\u001b[38;5;152m→\u001b[0m POST courseWork.studentSubmissions.modifyAttachments  202 Accepted\r\n"]
[8.9, "o", "\u001b[38;5;152m→\u001b[0m POST courseWork.studentSubmissions.turnIn             200 OK\r\n"]
[9.4, "o", "\u001b[38;5;120mok\u001b[0m  state=TURNED_IN  submission=Cg4I6P_KsZULEMqv6c0LGgZkb2NzLnYBKAQ  latency=3.2s\r\n"]
[10.6, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[10.9, "o", "classroom-submit submit-file --file ./lista3.pdf --query \"Lista 3\" --output json\r\n"]
[11.4, "o", "\u001b[38;5;152m{\u001b[0m\r\n  \u001b[38;5;152m\"ok\"\u001b[0m: false,\r\n  \u001b[38;5;152m\"error\"\u001b[0m: \"already_turned_in\",\r\n  \u001b[38;5;152m\"exit_code\"\u001b[0m: 5,\r\n  \u001b[38;5;152m\"state\"\u001b[0m: \"TURNED_IN\",\r\n  \u001b[38;5;152m\"hint\"\u001b[0m: \"submission is final; use --reclaim to revert\"\r\n\u001b[38;5;152m}\u001b[0m\r\n"]
[13.2, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[13.6, "o", "classroom-submit status --course ODUxMzc0NzU3ODU3 --coursework Nzk3MDIxMjk3MjU4\r\n"]
[14.0, "o", "STATE       TURNED_IN\r\nSUBMITTED   2026-05-28T13:00:14Z\r\nATTACHMENTS 1 file (lista3.pdf)\r\nLATE        no  (due 2026-05-30T23:59:00-03:00)\r\nDRAFT       no\r\n"]
[15.6, "o", "\u001b[38;5;141m~\u001b[0m \u001b[38;5;145m$\u001b[0m "]
[16.0, "o", "exit\r\n"]
